{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/web-shop-expo/browser",
  "routes": [
    {
      "src": "/rosenborg-api/(.*)",
      "dest": "https://www.rosenborgbakeri.no/shop/api/$1"
    },
    {
      "src": "/maschmanns-api/(.*)",
      "dest": "https://www.maschmanns.no/shop/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/products/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/pages(.*)",
      "dest": "/index.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/api/upload-image",
      "dest": "/api/upload-image.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/api/page-renderer.ts"
    }
  ]
}
